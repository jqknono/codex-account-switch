{
  "name": "codex-account-switch-vscode",
  "displayName": "Codex Account Switch",
  "description": "Codex Account Switch - VS Code extension",
  "version": "1.2.3",
  "publisher": "techfetch-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/jqknono/codex-account-switch"
  },
  "homepage": "https://github.com/jqknono/codex-account-switch",
  "bugs": {
    "url": "https://github.com/jqknono/codex-account-switch/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "codex",
    "account",
    "accounts",
    "auth",
    "quota",
    "chatgpt",
    "openai"
  ],
  "markdown": "github",
  "icon": "resources/icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codex-account-switch",
          "title": "Codex Account Switch: Accounts",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "codex-account-switch": [
        {
          "id": "codexAccountSwitchAccounts",
          "name": "",
          "icon": "resources/icon.svg",
          "showCollapseAll": true
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "codexAccountSwitchAccounts",
        "contents": "No accounts to display yet.\n[Import accounts](command:codex-account-switch.importAccounts)\n[Add account](command:codex-account-switch.addAccount)"
      }
    ],
    "commands": [
      {
        "command": "codex-account-switch.importAccounts",
        "title": "Codex Account Switch: Import Accounts",
        "icon": "$(folder-opened)"
      },
      {
        "command": "codex-account-switch.addAccount",
        "title": "Codex Account Switch: Add Account",
        "icon": "$(add)"
      },
      {
        "command": "codex-account-switch.reloginAccount",
        "title": "Codex Account Switch: Re-login Account",
        "icon": "$(sign-in)"
      },
      {
        "command": "codex-account-switch.renameAccount",
        "title": "Codex Account Switch: Rename Account",
        "icon": "$(edit)"
      },
      {
        "command": "codex-account-switch.removeAccount",
        "title": "Codex Account Switch: Remove Account",
        "icon": "$(trash)"
      },
      {
        "command": "codex-account-switch.useAccount",
        "title": "Codex Account Switch: Switch Account",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "codex-account-switch.switchMode",
        "title": "Codex Account Switch: Switch Mode",
        "icon": "$(plug)"
      },
      {
        "command": "codex-account-switch.refreshToken",
        "title": "Codex Account Switch: Refresh Token and Quota",
        "icon": "$(refresh)"
      },
      {
        "command": "codex-account-switch.refreshQuota",
        "title": "Codex Account Switch: Refresh Quota",
        "icon": "$(refresh)"
      },
      {
        "command": "codex-account-switch.exportAccounts",
        "title": "Codex Account Switch: Export Accounts",
        "icon": "$(export)"
      },
      {
        "command": "codex-account-switch.refreshList",
        "title": "Refresh List",
        "icon": "$(refresh)"
      },
      {
        "command": "codex-account-switch.reloadWindow",
        "title": "Codex Account Switch: Reload Window",
        "icon": "$(debug-restart)"
      },
      {
        "command": "codex-account-switch.expandAllAccounts",
        "title": "Codex Account Switch: Expand All Accounts",
        "icon": "$(expand-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codex-account-switch.importAccounts",
          "when": "view == codexAccountSwitchAccounts",
          "group": "navigation@1"
        },
        {
          "command": "codex-account-switch.addAccount",
          "when": "view == codexAccountSwitchAccounts",
          "group": "navigation@2"
        },
        {
          "command": "codex-account-switch.switchMode",
          "when": "view == codexAccountSwitchAccounts",
          "group": "navigation@3"
        },
        {
          "command": "codex-account-switch.refreshList",
          "when": "view == codexAccountSwitchAccounts",
          "group": "navigation@4"
        },
        {
          "command": "codex-account-switch.expandAllAccounts",
          "when": "view == codexAccountSwitchAccounts",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "codex-account-switch.useAccount",
          "when": "view == codexAccountSwitchAccounts && viewItem == account",
          "group": "inline@1"
        },
        {
          "command": "codex-account-switch.refreshToken",
          "when": "view == codexAccountSwitchAccounts && viewItem == account",
          "group": "inline@2"
        },
        {
          "command": "codex-account-switch.removeAccount",
          "when": "view == codexAccountSwitchAccounts && viewItem == account",
          "group": "inline@3"
        },
        {
          "command": "codex-account-switch.reloginAccount",
          "when": "view == codexAccountSwitchAccounts && viewItem == account",
          "group": "context@1"
        },
        {
          "command": "codex-account-switch.renameAccount",
          "when": "view == codexAccountSwitchAccounts && viewItem == account",
          "group": "context@2"
        },
        {
          "command": "codex-account-switch.removeAccount",
          "when": "view == codexAccountSwitchAccounts && viewItem == account",
          "group": "context@3"
        }
      ]
    },
    "configuration": {
      "title": "Codex Account Switch",
      "properties": {
        "codex-account-switch.quotaRefreshInterval": {
          "type": "number",
          "default": 300,
          "minimum": 60,
          "description": "Automatic quota refresh interval for the account list and status bar, in seconds"
        },
        "codex-account-switch.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the current account quota in the status bar"
        },
        "codex-account-switch.reloadWindowAfterSwitch": {
          "type": "string",
          "default": "prompt",
          "enum": [
            "never",
            "prompt",
            "always"
          ],
          "enumDescriptions": [
            "Do not prompt or reload the window after switching accounts",
            "Prompt to reload the window after switching accounts so the Codex extension can re-read auth",
            "Always reload the window after switching accounts so the Codex extension can re-read auth"
          ],
          "description": "How VS Code window reload should be handled after switching accounts"
        },
        "codex-account-switch.authDirectory": {
          "type": "string",
          "default": "",
          "description": "Directory used to save and load auth_{name}.json files. Leave empty to use the default Codex config directory."
        }
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "bundle": "node ./scripts/build.mjs",
    "build": "npm run typecheck && npm run bundle",
    "dev": "node ./scripts/build.mjs --watch",
    "test": "npm run build && node --test test/**/*.test.js",
    "package": "npm --prefix ../.. run build:core && npm run build && npx @vscode/vsce package --no-dependencies --allow-missing-repository",
    "publish:openvsx": "npm run package && node ./scripts/publish-openvsx.mjs",
    "publish:marketplace": "npx @vscode/vsce publish --no-dependencies",
    "publish:preview": "npx @vscode/vsce publish --no-dependencies --pre-release"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
