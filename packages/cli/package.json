{
  "name": "codex-account-switch",
    "version": "1.3.6",
  "description": "Quick switch between multiple Codex CLI accounts",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "bin": {
    "codex-account-switch": "dist/index.js"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc --emitDeclarationOnly && node ./scripts/build.mjs",
    "dev": "tsc --watch",
    "test": "npm run build && node --test test/**/*.test.js",
    "prepack": "npm run build",
    "publish:npm": "npm publish --access public"
  },
  "keywords": [
    "codex",
    "cli",
    "account",
    "switch"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@codex-account-switch/core": "*",
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
