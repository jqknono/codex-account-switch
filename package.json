{
  "name": "codex-account-switch-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Codex CLI multi-account switching tool - monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:cli && npm run build:vscode",
    "build:core": "npm run build -w packages/core",
    "build:cli": "npm run build -w packages/cli",
    "build:vscode": "npm run build -w packages/vscode",
    "test": "npm run test -w packages/core && npm run test -w packages/cli && npm run test -w packages/vscode",
    "audit": "npm audit --workspaces --include-workspace-root",
    "package:vscode": "npm run package -w packages/vscode",
    "prepack:cli": "npm run prepack -w packages/cli",
    "publish:vscode:openvsx": "npm run publish:openvsx -w packages/vscode",
    "publish:vscode": "npm run publish:marketplace -w packages/vscode",
    "publish:vscode:preview": "npm run publish:preview -w packages/vscode",
    "publish:cli": "npm run publish:npm -w packages/cli",
    "dev:core": "npm run dev -w packages/core",
    "dev:cli": "npm run dev -w packages/cli",
    "dev:vscode": "npm run dev -w packages/vscode"
  },
  "license": "MIT"
}
